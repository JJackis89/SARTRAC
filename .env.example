# SARTRAC Production Environment Configuration
# Copy this file to .env and fill in your actual values

# Application Configuration
VITE_APP_NAME=SARTRAC
VITE_APP_VERSION=2.0.0
VITE_NODE_ENV=production

# API Endpoints
VITE_API_BASE_URL=https://your-api-server.com/api
VITE_FORECAST_API_URL=https://github.com/JJackis89/SARTRAC/releases/latest/download

# Satellite Data Sources
# ERDDAP Servers for VIIRS and OLCI data
VITE_ERDDAP_VIIRS_URL=https://coastwatch.pfeg.noaa.gov/erddap
VITE_ERDDAP_OLCI_URL=https://oceandata.sci.gsfc.nasa.gov/erddap
VITE_ERDDAP_BACKUP_URL=https://upwell.pfeg.noaa.gov/erddap

# Google Earth Engine (if using GEE backend)
VITE_GEE_SERVICE_URL=https://your-gee-service.com/api
VITE_GEE_API_KEY=your_gee_api_key_here

# Satellite Data Configuration
VITE_SATELLITE_CACHE_DURATION=3600000
VITE_SATELLITE_TIMEOUT=30000
VITE_SATELLITE_RETRY_ATTEMPTS=3

# Forecast Configuration
VITE_FORECAST_CACHE_DURATION=1800000
VITE_FORECAST_UPDATE_INTERVAL=3600000
VITE_MAX_FORECAST_DAYS=7

# Map Configuration
VITE_DEFAULT_MAP_CENTER_LAT=5.6037
VITE_DEFAULT_MAP_CENTER_LNG=-0.1870
VITE_DEFAULT_ZOOM_LEVEL=7
VITE_MAX_ZOOM_LEVEL=18

# Performance Configuration
VITE_ENABLE_SERVICE_WORKER=true
VITE_ENABLE_PWA=true
VITE_CHUNK_SIZE_WARNING_LIMIT=1000

# Analytics and Monitoring (optional)
VITE_ANALYTICS_ID=your_analytics_id_here
VITE_SENTRY_DSN=your_sentry_dsn_here

# Feature Flags
VITE_ENABLE_SATELLITE_INTEGRATION=true
VITE_ENABLE_BEACHED_DETECTION=true
VITE_ENABLE_COASTSNAP_INTEGRATION=true
VITE_ENABLE_DEBUG_MODE=false